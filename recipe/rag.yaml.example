# SHIORI Intelligence Pipeline - Example Configuration
# Rename this file to rag.yaml to run the pipeline.

global:
  timezone: Asia/Tokyo
  log_level: info
  bq_project_id: your-gcp-project-id
  bq_dataset: shiori_archive
  max_workers: 4

plugins:
  # ----------------------------------------------------------------
  # 1. SUBSCRIPTION: Where to get data from
  # ----------------------------------------------------------------

  # RSS Subscription
  - module: Subscription::RSS
    config:
      urls:
        - https://rss.nytimes.com/services/xml/rss/nyt/HomePage.xml
        - https://www.nature.com/nature.rss
      limit: 5
      state_file: data/rss_state.txt

  # Google Keep Subscription (Example)
  #- module: Subscription::GoogleKeep
  #  config:
  #    path: /path/to/your/google-keep-takeout

  # ----------------------------------------------------------------
  # 2. FILTER: How to process the data
  # ----------------------------------------------------------------

  # Gemini AI Enrichment
  - module: Filter::LLM::MetadataEnricher
    config:
      api_key: YOUR_GEMINI_API_KEY
      model: gemini-1.5-flash
      # Optional: custom prompt
      # prompt: "..."

  # Vectorization (Mock or real)
  - module: Filter::LLM::Vectorize
    config:
      model: text-embedding-004

  # ----------------------------------------------------------------
  # 3. PUBLISH: Where to send the data
  # ----------------------------------------------------------------

  # Twitter/X Publishing
  - module: Publish::Twitter
    config:
      consumer_key: YOUR_CONSUMER_KEY
      consumer_secret: YOUR_CONSUMER_SECRET
      access_token: YOUR_ACCESS_TOKEN
      access_token_secret: YOUR_ACCESS_TOKEN_SECRET

  # Hatena Blog Publishing
  - module: Publish::Hatena
    config:
      hatena_id: YOUR_HATENA_ID
      blog_id: YOUR_BLOG_ID.hatenablog.com
      api_key: YOUR_HATENA_API_KEY

  # BigQuery Publishing
  - module: Publish::BigQuery
    config:
      table_id: entries_all
