# ── [7] 動画作成（静止画＋音声）────────────────────────────
from pydub import AudioSegment
import moviepy.editor as mp
from PIL import Image, ImageDraw, ImageFont
import numpy as np

print("🎬 動画生成中...")

# 背景画像作成（シンプル和風）
def create_bg_image(title, width=1280, height=720):
    img = Image.new('RGB', (width, height), color=(20, 20, 40))  # 濃紺背景
    draw = ImageDraw.Draw(img)
    
    # 簡易フォント（Colab 環境用）
    try:
        font = ImageFont.truetype("/usr/share/fonts/truetype/takao-pgothic/TakaoPGothic.ttf", 36)
        title_font = ImageFont.truetype("/usr/share/fonts/truetype/takao-pgothic/TakaoPGothic.ttf", 48)
    except:
        font = ImageFont.load_default()
        title_font = font
    
    # タイトル表示
    draw.text((640, 100), "🎭 SF落語劇場", fill=(255, 215, 0), font=title_font, anchor="mt")
    
    # 論文タイトル（折り返し処理）
    words = title.split()
    lines, current = [], ""
    for word in words:
        if len(current) + len(word) < 40:
            current += " " + word
        else:
            lines.append(current)
            current = word
    if current:
        lines.append(current)
    
    y_pos = 200
    for line in lines[:5]:  # 最大 5 行
        draw.text((640, y_pos), line.strip(), fill=(200, 200, 255), font=font, anchor="mt")
        y_pos += 50
    
    # 装飾
    draw.rectangle([(100, 600), (1180, 620)], fill=(100, 100, 150))
    draw.text((640, 610), "arXiv × AI × 落語", fill=(255, 255, 255), font=font, anchor="mt")
    
    return img

bg_image_path = "/content/bg.png"
img = create_bg_image(paper.title)
img.save(bg_image_path)

# 動画作成（画像＋音声）
