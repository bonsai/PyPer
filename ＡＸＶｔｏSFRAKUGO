# ── [4] arXiv API からランダム論文を取得 ─────────────────────
import arxiv
import time

def fetch_random_paper():
    """arXiv API からランダムに論文を取得"""
    category = random.choice(CONFIG["categories"])
    search = arxiv.Search(
        query=f"cat:{category}",
        max_results=CONFIG["max_results"],
        sort_by=arxiv.SortCriterion.SubmittedDate
    )
    papers = list(search.results())
    
    if not papers:
        raise ValueError("論文が見つかりませんでした")
    
    # ランダムに 1 本選択（新しすぎないものを選ぶ）
    selected = random.choice(papers[5:])  # 最新 5 本は除外
    return selected

print("📚 論文を取得中...")
paper = fetch_random_paper()
print(f"🎯 選択された論文: {paper.title[:60]}...")
print(f"🔗 arXiv ID: {paper.entry_id.split('/')[-1]}")
print(f"📝 要約: {paper.summary[:200]}...")

